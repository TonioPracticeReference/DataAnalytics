---
import { site } from "../data/site";
---
<footer class="border-t border-white/8 py-8">
  <div class="container-shell flex flex-col gap-4 text-sm text-slate-400 sm:flex-row sm:items-center sm:justify-between">
    <p>© 2026 {site.name}. Built with Astro and Tailwind CSS.</p>
    <div class="flex flex-wrap gap-4">
      {site.socialLinks.map((item) => (
        <a class="hover:text-white" href={item.href} target={item.href.startsWith("http") ? "_blank" : undefined} rel="noreferrer">{item.label}</a>
      ))}
    </div>
  </div>
</footer>
