---
import { projects } from "../data/site";
---
<section id="projects" class="section-space">
  <div class="container-shell space-y-8">
    <div class="max-w-3xl space-y-4">
      <span class="eyebrow">Projects</span>
      <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">Case-study style work with cleaner structure and stronger presentation.</h2>
      <p class="text-base leading-8 text-slate-300 sm:text-lg">
        Each card is built to read more like a focused project summary than a generic portfolio tile.
      </p>
    </div>

    <div class="grid gap-6 lg:grid-cols-2">
      {projects.map((project) => (
        <article class="group panel-soft overflow-hidden">
          <div class="relative aspect-[16/10] overflow-hidden border-b border-white/8 bg-slate-900">
            <img src={project.image} alt={project.title} class="h-full w-full object-cover transition duration-500 group-hover:scale-105" loading="lazy" />
            <div class="absolute inset-x-0 top-4 flex justify-between px-4">
              <span class="rounded-full border border-white/10 bg-slate-950/70 px-3 py-1 text-xs text-sky-100">{project.category}</span>
            </div>
          </div>
          <div class="space-y-5 p-7">
            <div>
              <h3 class="text-2xl font-semibold text-white">{project.title}</h3>
              <p class="mt-3 text-sm leading-7 text-slate-300">{project.description}</p>
            </div>
            <div class="flex flex-wrap gap-3">
              {project.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
            <div class="flex flex-wrap gap-3">
              {project.links.map((link) => (
                <a class="btn-secondary px-4 py-2" href={link.href} target="_blank" rel="noreferrer">{link.label}</a>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
