---
const nav = [
  { label: "About", href: "#about" },
  { label: "Experience", href: "#experience" },
  { label: "Projects", href: "#projects" },
  { label: "Contact", href: "#contact" },
];
---
<header class="sticky top-0 z-50 border-b border-white/8 bg-slate-950/70 backdrop-blur-xl">
  <div class="container-shell flex h-18 items-center justify-between gap-4 py-4">
    <a href="#top" class="flex items-center gap-3 text-sm font-semibold tracking-[0.2em] text-white uppercase">
      <span class="flex size-10 items-center justify-center rounded-2xl border border-white/10 bg-white/6 text-sky-200">MN</span>
      <span class="hidden sm:inline">Mark Anthony Nene</span>
    </a>

    <nav class="hidden items-center gap-7 md:flex">
      {nav.map((item) => (
        <a class="nav-link" href={item.href}>{item.label}</a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a class="btn-secondary hidden px-4 py-2 sm:inline-flex" href="#contact">Let's Talk</a>
      <button id="menu-toggle" class="btn-secondary px-4 py-2 md:hidden" type="button" aria-expanded="false" aria-controls="mobile-nav">Menu</button>
    </div>
  </div>

  <div id="mobile-nav" class="hidden border-t border-white/8 md:hidden">
    <div class="container-shell flex flex-col gap-3 py-4">
      {nav.map((item) => (
        <a class="nav-link" href={item.href}>{item.label}</a>
      ))}
    </div>
  </div>
</header>

<script>
  const menuToggle = document.getElementById("menu-toggle");
  const mobileNav = document.getElementById("mobile-nav");
  menuToggle?.addEventListener("click", () => {
    const isOpen = !mobileNav?.classList.contains("hidden");
    mobileNav?.classList.toggle("hidden");
    menuToggle.setAttribute("aria-expanded", String(!isOpen));
  });
</script>
